# ============================================================================
# Database Configuration - Local Docker PostgreSQL
# ============================================================================
# Format: postgresql://postgres:postgres@localhost:5433/app_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/app_db

# ============================================================================
# Microsoft Entra ID Configuration
# ============================================================================
# Two app registrations are required: one for the API, one for the SPA.
# Neither registration requires a client secret — this backend validates
# tokens via RS256 signature only (no secret involved).

# API app registration — tenant GUID (from Azure Portal > Overview)
ENTRA_TENANT_ID=your-tenant-id

# API app registration client ID (the "backend" app)
ENTRA_API_CLIENT_ID=your-api-client-id

# Expected audience: use the GUID or the api://<client-id> URI
# whichever your app registration advertises in its manifest.
ENTRA_API_AUDIENCE=api://your-api-client-id

# Required scope (created under your API app registration)
ENTRA_API_SCOPE=api://your-api-client-id/access_as_user

# SPA app registration client ID (the "frontend" app — public, no secret)
ENTRA_SPA_CLIENT_ID=your-spa-client-id

# ============================================================================
# Server Configuration
# ============================================================================
ENVIRONMENT=development
DEBUG=True
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:4200,http://localhost:4300

# ============================================================================
# Azure OpenAI Configuration (for chatbot)
# ============================================================================
AZURE_OPENAI_BASE_URL=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_API_KEY=your-azure-openai-key

# ============================================================================
# Alternative LLM Providers
# ============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key
OLLAMA_BASE_URL=http://localhost:11434/v1
