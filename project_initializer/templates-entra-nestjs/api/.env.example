# =============================================================================
# NestJS + Microsoft Entra ID Backend - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE - Local Docker PostgreSQL
# -----------------------------------------------------------------------------

# Runtime queries (Prisma)
# REQUIRED — app fails fast at startup if unset
DATABASE_URL="postgresql://postgres:postgres@db:5432/app_db?schema=public"  # REQUIRED

# Migrations (DIRECT_URL = session connection, not transaction pooler)
# REQUIRED — app fails fast at startup if unset
DIRECT_URL="postgresql://postgres:postgres@db:5432/app_db?schema=public"  # REQUIRED

# Optional individual vars (docker-compose injects them; kept for clarity)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# MICROSOFT ENTRA ID AUTHENTICATION
# No client secret required — validation is RS256 signature-only via JWKS
# -----------------------------------------------------------------------------

# Directory (tenant) ID from your Entra tenant
# Found in: Entra portal > App registrations > your API app > Overview
# REQUIRED
ENTRA_TENANT_ID=your-tenant-id  # REQUIRED

# Application (client) ID of the API registration
# Found in: Entra portal > App registrations > your API app > Overview
# REQUIRED
ENTRA_API_CLIENT_ID=your-api-client-id  # REQUIRED

# Audience — GUID or api://{client-id} URI exposed by the API registration
# Found in: Entra portal > App registrations > your API app > Expose an API
# REQUIRED
ENTRA_API_AUDIENCE=api://your-api-client-id  # REQUIRED

# Required scope (e.g. access_as_user) that every caller must present
# Found in: Entra portal > App registrations > your API app > Expose an API
# REQUIRED
ENTRA_API_SCOPE=access_as_user  # REQUIRED

# SPA client ID — used by the Angular frontend only; kept here for reference
ENTRA_SPA_CLIENT_ID=your-spa-client-id

# -----------------------------------------------------------------------------
# AZURE OPENAI CONFIGURATION
# -----------------------------------------------------------------------------
AZURE_OPENAI_RESOURCE_NAME=your-resource-name
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_GPT4O_DEPLOYMENT_ID=gpt-4o
AZURE_OPENAI_GPT5_DEPLOYMENT_ID=gpt-5

# -----------------------------------------------------------------------------
# ALTERNATIVE LLM PROVIDERS
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OLLAMA_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# REDIS (BullMQ queue backend)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost  # Use 'redis' when running via docker-compose
REDIS_PORT=6379
